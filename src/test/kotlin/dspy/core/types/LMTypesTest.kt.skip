class LMHistoryEntryTest : FunSpec({
    test("creates entry from request and response") {
        val request = LMRequest(
            model = "gpt-4",
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello"))))
        )
        val response = LMResponse.fromText("Answer")
        val entry = LMHistoryEntry(
            request = request,
            response = response,
            timestamp = "2024-01-01T00:00:00",
            uuid = "uuid-123"
        )

        entry.model shouldBe "gpt-4"
        entry.prompt shouldBe "Hello"
        entry.outputs shouldBe listOf("Answer")
    }

    test("usage property") {
        // TODO: val response = LMResponse.fromText("Answer", usage = LMUsage.create(10, 20)) - not yet implemented
    }

    test("kwargs property") {
        val config = LMConfig(temperature = 0.7f, maxTokens = 1000)
        val request = LMRequest(
            model = "gpt-4",
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello")))),
            config = config
        )
        val response = LMResponse.fromText("Answer")
        val entry = LMHistoryEntry(
            request = request,
            response = response,
            timestamp = "2024-01-01T00:00:00",
            uuid = "uuid-123"
        )

        entry.request.config.temperature shouldBe 0.7f
        entry.request.config.maxTokens shouldBe 1000
    }

    test("messages property") {
        val request = LMRequest(
            model = "gpt-4",
            messages = listOf(
                LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello")))
            )
        )
        val response = LMResponse.fromText("Answer")
        val entry = LMHistoryEntry(
            request = request,
            response = response,
            timestamp = "2024-01-01T00:00:00",
            uuid = "uuid-123"
        )

        entry.messages!!.size shouldBe 1
        (entry.messages!![0] as Map<*, *>)["role"] shouldBe "user"
    }

    test("responseModel property") {
        val request = LMRequest(
            model = "gpt-4",
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello"))))
        )
        val response = LMResponse.fromText("Answer", model = "gpt-4-turbo")
        val entry = LMHistoryEntry(
            request = request,
            response = response,
            timestamp = "2024-01-01T00:00:00",
            uuid = "uuid-123"
        )

        entry.responseModel shouldBe "gpt-4-turbo"
    }

    test("operator get for known keys") {
        val request = LMRequest(
            model = "gpt-4",
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello"))))
        )
        val response = LMResponse.fromText("Answer")
        val entry = LMHistoryEntry(
            request = request,
            response = response,
            timestamp = "2024-01-01T00:00:00",
            uuid = "uuid-123"
        )

        entry["model"] shouldBe "gpt-4"
        entry["outputs"] shouldBe listOf("Answer")
        entry["prompt"] shouldBe "Hello"
    }

    test("operator get for unknown key") {
        val request = LMRequest(
            model = "gpt-4",
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello"))))
        )
        val response = LMResponse.fromText("Answer")
        val entry = LMHistoryEntry(
            request = request,
            response = response,
            timestamp = "2024-01-01T00:00:00",
            uuid = "uuid-123"
        )

        entry["unknown"] shouldBe null
    }
})

class LMRequestPatchTest : FunSpec({
    test("creates patch with values") {
        val patch = LMRequestPatch(
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello")))),
            tools = listOf(LMToolSpec(name = "search")),
            config = LMConfig(temperature = 0.7)
        )
        patch.messages.size shouldBe 1
        patch.tools.size shouldBe 1
        patch.config?.temperature shouldBe 0.7
    }

    test("merge combines patches") {
        val patch1 = LMRequestPatch(
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello")))),
        )
        val patch2 = LMRequestPatch(
            messages = listOf(LMMessage(role = "assistant", parts = listOf(LMTextPart(text = "Answer")))),
            tools = listOf(LMToolSpec(name = "search"))
        )
        val merged = patch1.merge(patch2)
        merged.messages.size shouldBe 2
        merged.tools.size shouldBe 1
    }

    test("asLmKwargs with config") {
        val patch = LMRequestPatch(config = LMConfig(temperature = 0.7f, maxTokens = 1000))
        val kwargs = patch.toKwargs()
        kwargs["temperature"] shouldBe 0.7f
        kwargs["maxTokens"] shouldBe 1000
    }

    test("asLmKwargs with tools") {
        val patch = LMRequestPatch(tools = listOf(LMToolSpec(name = "search")))
        val kwargs = patch.toKwargs()
        (kwargs["tools"] as List<*>).size shouldBe 1
    }
})

class LMRequestTest : FunSpec({
    test("creates request from prompt") {
        val request = LMRequest.fromCall(model = "gpt-4", messages = listOf("Hello"))
        request.model shouldBe "gpt-4"
        request.messages.size shouldBe 1
        request.messages[0].text shouldBe "Hello"
    }

    test("creates request from messages") {
        val messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello"))))
        val request = LMRequest.fromCall(model = "gpt-4", messages = messages)
        request.model shouldBe "gpt-4"
        request.messages shouldBe messages
    }

    test("creates request with config") {
        // TODO: val request = LMRequest.fromCall(model = "gpt-4", messages = listOf("Hello"), "temperature" to 0.7f, "maxTokens" to 1000) - not yet implemented
    }

    test("withConfigOverrides") {
        val request = LMRequest(
            model = "gpt-4",
            messages = listOf(LMMessage(role = "user", parts = listOf(LMTextPart(text = "Hello")))),
            config = LMConfig(temperature = 0.5f)
        )
        val overridden = request.withConfigOverrides(mapOf("temperature" to 0.8f))
        overridden.config.temperature shouldBe 0.8f
    }
})

class LMReasoningConfigTest : FunSpec({
    test("fromValue with map") {
        val config = LMReasoningConfig.fromValue(mapOf("effort" to "high"))
        config.effort shouldBe "high"
    }

    test("fromValue with string") {
        val config = LMReasoningConfig.fromValue("medium")
        config.effort shouldBe "medium"
    }

    test("fromValue with null") {
        val config = LMReasoningConfig.fromValue(null)
        config.effort shouldBe null
    }

    test("fromValue with overrides") {
        val config = LMReasoningConfig.fromValue(null, mapOf("effort" to "low"))
        config.effort shouldBe "low"
    }
})

class LMToolChoiceTest : FunSpec({
    test("fromValue with map") {
        val choice = LMToolChoice.fromValue(mapOf("mode" to "required"))
        choice.mode shouldBe "required"
    }

    test("fromValue with string") {
        val choice = LMToolChoice.fromValue("auto")
        choice.mode shouldBe "auto"
    }

    test("fromValue with null") {
        val choice = LMToolChoice.fromValue(null)
        choice.mode shouldBe "auto"
    }

    test("fromValue with parallel") {
        val choice = LMToolChoice.fromValue(null, mapOf("parallel" to true))
        choice.parallel shouldBe true
    }
})

class LMCacheConfigTest : FunSpec({
    test("fromValue with map") {
        val config = LMCacheConfig.fromValue(mapOf("enabled" to true))
        config.enabled shouldBe true
    }

    test("fromValue with boolean") {
        val config = LMCacheConfig.fromValue(true)
        config.enabled shouldBe true
    }

    test("fromValue with null") {
        val config = LMCacheConfig.fromValue(null)
        config.enabled shouldBe null
    }

    test("fromValue with rolloutId") {
        val config = LMCacheConfig.fromValue(null, mapOf("rolloutId" to "test"))
        config.rolloutId shouldBe "test"
    }
})

class LMPromptCacheConfigTest : FunSpec({
    test("fromValue with map") {
        val config = LMPromptCacheConfig.fromValue(mapOf("enabled" to true, "key" to "test"))
        config.enabled shouldBe true
        config.key shouldBe "test"
    }

    test("fromValue with boolean") {
        val config = LMPromptCacheConfig.fromValue(true)
        config.enabled shouldBe true
    }

    test("fromValue with null") {
        val config = LMPromptCacheConfig.fromValue(null)
        config.enabled shouldBe null
        config.key shouldBe null
    }
})
