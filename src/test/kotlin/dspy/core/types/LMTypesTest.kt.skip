    test("toValues") {
        // TODO: response.toValues() - not yet implemented
    }

    test("toOutputs") {
        // TODO: response.toOutputs() - not yet implemented
    }

    test("requires at least one output") {
        try {
            LMResponse(outputs = emptyList())
            io.kotest.assertions.fail("Should have thrown IllegalArgumentException")
        } catch (e: IllegalArgumentException) {
            e.message shouldBe "LMResponse requires at least one output"
